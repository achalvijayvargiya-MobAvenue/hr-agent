# ── Required ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./hr_agent.db

# ── OpenAI models ─────────────────────────────────────────────────────────────
EXTRACTION_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
RERANK_MODEL=gpt-4o

# ── Extraction behaviour ──────────────────────────────────────────────────────
# How many times to retry if LLM returns an invalid schema
MAX_EXTRACTION_RETRIES=2

# ── Matching behaviour ────────────────────────────────────────────────────────
# How many top candidates (by rule+vector) are sent to LLM for reranking
TOP_N_FOR_RERANK=20

# ── Final score weights (must sum to 1.0) ─────────────────────────────────────
RULE_WEIGHT=0.4
VECTOR_WEIGHT=0.2
LLM_WEIGHT=0.4

# ── Rule score sub-weights (must sum to 1.0) ──────────────────────────────────
SKILL_WEIGHT=0.4
EXPERIENCE_WEIGHT=0.2
ROLE_WEIGHT=0.2
INDUSTRY_WEIGHT=0.2

# ── Logging ───────────────────────────────────────────────────────────────────
# Use DEBUG to see full extracted values, scores, and LLM responses
# Use INFO for clean production output
LOG_LEVEL=INFO
LOG_FILE=logs/hr_agent.log
